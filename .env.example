# ─── Required ────────────────────────────────────────────────────────────────

# Resend API key for sending emails (https://resend.com)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXX

# Sender address (must be a verified domain in Resend)
EMAIL_FROM=test@gmail.com

# Recipient address for job-update notifications
EMAIL_TO=test@gmail.com

# JSON array of Naukri accounts to automate
# Each entry: { "email": "...", "password": "..." }
NAUKRI_ACCOUNTS=[{"name": "Test Name", "email":"test@gmail.com","password":"test@123"}]

# ─── Optional — Browser ───────────────────────────────────────────────────────

# Run Chromium in headless mode (default: true)
HEADLESS=false

# ─── Optional — Retries ──────────────────────────────────────────────────────

# Number of retry attempts on failure (default: 3)
RETRY_COUNT=3

# Delay in ms between retries (default: 1000)
RETRY_DELAY=1000

# ─── Optional — Network ──────────────────────────────────────────────────────

# How long to wait before retrying a network check in ms (default: 30000)
NETWORK_RETRY_INTERVAL=30000

# Network request timeout in ms (default: 10000)
NETWORK_TIMEOUT=10000

# ─── Optional — Scheduling ───────────────────────────────────────────────────

# IANA timezone for scheduling (default: Asia/Kolkata)
TIMEZONE=Asia/Kolkata

# Skip schedule check and run immediately (default: false)
FORCE_RUN=false

# ─── Optional — Features ─────────────────────────────────────────────────────

# Send a success email after each run (default: false)
ENABLE_SUCCESS_EMAIL=false

# Save screenshots during automation (default: true)
ENABLE_SCREENSHOTS=true

# Persist browser storage/session state between runs (default: true)
ENABLE_STORAGE_STATE=true

# Send emails as HTML (default: true)
ENABLE_HTML_EMAIL=true